  "proposedNextMeasurementCommand": ".\\artifacts\\bin\\Release\\CursorMirror.Calibrator.exe --auto-run --duration-seconds 30 --output .\\poc\\cursor-prediction-v7\\runs\\raw\\current-default\\calibration-current-default-001.zip --exit-after-run",
  "proposedNextScoringCommand": "node .\\poc\\cursor-prediction-v7\\scripts\\score-calibration.js --baseline current-default --run current-default=.\\poc\\cursor-prediction-v7\\runs\\raw\\current-default\\calibration-current-default-001.zip --out .\\poc\\cursor-prediction-v7\\runs\\summaries\\baseline-score.json"
}
