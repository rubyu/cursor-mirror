      "requiresCandidateBuild": true
    },
    {
      "id": "gain-grid-075",
      "role": "candidate",
      "measurementRequired": true,
      "requiresCandidateBuild": true
    },
    {
      "id": "gain-grid-100",
      "role": "candidate",
      "measurementRequired": true,
      "requiresCandidateBuild": true
    },
    {
      "id": "safe-ridge-residual-guarded",
